{
  "$schema": "https://design-tokens.org/schema.json",
  "primitive": {
    "color": {
      "paper": {
        "50": { "$value": "#FBF5E7", "$type": "color" },
        "100": { "$value": "#F1E4C7", "$type": "color" },
        "200": { "$value": "#E6D3A9", "$type": "color" }
      },
      "crate": {
        "900": { "$value": "#33251A", "$type": "color" },
        "700": { "$value": "#6B4A2E", "$type": "color" },
        "500": { "$value": "#9C6B3F", "$type": "color" },
        "300": { "$value": "#C89A61", "$type": "color" }
      },
      "olive": {
        "600": { "$value": "#57623B", "$type": "color" },
        "400": { "$value": "#828F5C", "$type": "color" }
      },
      "paprika": {
        "500": { "$value": "#C1440E", "$type": "color" },
        "700": { "$value": "#8A2F09", "$type": "color" }
      },
      "ink": {
        "900": { "$value": "#2A2117", "$type": "color" },
        "500": { "$value": "#6E5F49", "$type": "color" }
      }
    },
    "font": {
      "display": { "$value": "var(--font-newsreader), 'Newsreader', Georgia, serif", "$type": "fontFamily" },
      "sans": { "$value": "var(--font-work-sans), system-ui, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "var(--font-space-mono), 'SF Mono', monospace", "$type": "fontFamily" }
    },
    "motion": {
      "duration": {
        "micro": { "$value": "180ms", "$type": "duration" },
        "base": { "$value": "320ms", "$type": "duration" },
        "reveal": { "$value": "1s", "$type": "duration" },
        "settle": { "$value": "1.6s", "$type": "duration" }
      },
      "ease": {
        "out-expo": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" },
        "crate-drop": { "$value": "cubic-bezier(0.34, 1.26, 0.64, 1)", "$type": "cubicBezier" }
      }
    },
    "tracking": {
      "display": { "$value": "-0.01em", "$type": "dimension" },
      "label": { "$value": "0.18em", "$type": "dimension" }
    }
  },
  "semantic": {
    "background": { "$value": "{primitive.color.paper.50}", "$type": "color" },
    "foreground": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "card": { "$value": "{primitive.color.paper.100}", "$type": "color" },
    "card-foreground": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "popover": { "$value": "{primitive.color.paper.100}", "$type": "color" },
    "popover-foreground": { "$value": "{primitive.color.ink.900}", "$type": "color" },
    "primary": { "$value": "{primitive.color.crate.900}", "$type": "color" },
    "primary-foreground": { "$value": "{primitive.color.paper.50}", "$type": "color" },
    "secondary": { "$value": "{primitive.color.olive.600}", "$type": "color" },
    "secondary-foreground": { "$value": "{primitive.color.paper.50}", "$type": "color" },
    "muted": { "$value": "{primitive.color.paper.100}", "$type": "color" },
    "muted-foreground": { "$value": "{primitive.color.ink.500}", "$type": "color" },
    "accent": { "$value": "{primitive.color.paprika.500}", "$type": "color" },
    "accent-foreground": { "$value": "{primitive.color.paper.50}", "$type": "color" },
    "destructive": { "$value": "{primitive.color.paprika.700}", "$type": "color" },
    "border": { "$value": "{primitive.color.crate.700}", "$type": "color" },
    "input": { "$value": "{primitive.color.paper.100}", "$type": "color" },
    "ring": { "$value": "{primitive.color.paprika.500}", "$type": "color" },
    "radius": { "$value": "0.4rem", "$type": "dimension" },
    "paprika": { "$value": "{primitive.color.paprika.500}", "$type": "color" },
    "paprika-dim": { "$value": "{primitive.color.paprika.700}", "$type": "color" },
    "olive": { "$value": "{primitive.color.olive.600}", "$type": "color" },
    "wood": { "$value": "{primitive.color.crate.700}", "$type": "color" },
    "wood-dark": { "$value": "{primitive.color.crate.900}", "$type": "color" },
    "wood-light": { "$value": "{primitive.color.crate.300}", "$type": "color" },
    "surface-line": { "$value": "{primitive.color.crate.500}", "$type": "color" },
    "type-display": { "$value": "{primitive.font.display}", "$type": "fontFamily" },
    "type-body": { "$value": "{primitive.font.sans}", "$type": "fontFamily" },
    "type-label": { "$value": "{primitive.font.mono}", "$type": "fontFamily" },
    "ease-reveal": { "$value": "{primitive.motion.ease.out-expo}", "$type": "cubicBezier" },
    "ease-crate": { "$value": "{primitive.motion.ease.crate-drop}", "$type": "cubicBezier" },
    "duration-micro": { "$value": "{primitive.motion.duration.micro}", "$type": "duration" },
    "duration-base": { "$value": "{primitive.motion.duration.base}", "$type": "duration" },
    "duration-reveal": { "$value": "{primitive.motion.duration.reveal}", "$type": "duration" },
    "tracking-display": { "$value": "{primitive.tracking.display}", "$type": "dimension" },
    "tracking-label": { "$value": "{primitive.tracking.label}", "$type": "dimension" }
  },
  "component": {
    "hero": {
      "title-size": { "$value": "clamp(2.75rem, 8vw, 6.5rem)", "$type": "dimension" },
      "title-leading": { "$value": "1.02", "$type": "number" },
      "kicker-size": { "$value": "0.72rem", "$type": "dimension" }
    },
    "crate": {
      "shadow": {
        "$value": "0 18px 30px -14px rgba(42, 33, 23, 0.45), 0 2px 0 rgba(51, 37, 26, 0.5)",
        "$type": "shadow"
      },
      "slat-gradient": {
        "$value": "repeating-linear-gradient(180deg, rgba(51,37,26,0.08) 0px, rgba(51,37,26,0.08) 2px, transparent 2px, transparent 22px)",
        "$type": "gradient"
      },
      "label-bg": { "$value": "{primitive.color.paper.50}", "$type": "color" },
      "brace": { "$value": "{primitive.color.crate.900}", "$type": "color" }
    },
    "button": {
      "primary-bg": { "$value": "{primitive.color.crate.900}", "$type": "color" },
      "primary-fg": { "$value": "{primitive.color.paper.50}", "$type": "color" },
      "primary-hover-bg": { "$value": "{primitive.color.paprika.500}", "$type": "color" },
      "primary-hover-fg": { "$value": "{primitive.color.paper.50}", "$type": "color" },
      "ghost-border": { "$value": "{primitive.color.crate.700}", "$type": "color" },
      "ghost-hover-border": { "$value": "{primitive.color.paprika.500}", "$type": "color" }
    }
  }
}
